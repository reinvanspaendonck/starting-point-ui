{
  "name": "starting-point-ui",
  "version": "0.24.1",
  "description": "A framework-agnostic component library for Tailwind CSS, inspired by shadcn/ui",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "style": "./dist/index.css",
  "exports": {
    ".": {
      "style": "./dist/index.css",
      "import": "./dist/index.js",
      "default": "./dist/index.css"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --noEmit && eslint src/ && node build.mjs && dts-bundle-generator --no-check --inline-declare-global -o dist/index.d.ts src/js/index.ts",
    "dev": "node build.mjs --watch",
    "check-types": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@floating-ui/dom": "^1.7.4",
    "dts-bundle-generator": "^9.5.1",
    "esbuild": "^0.27.4",
    "eslint": "^9",
    "postcss": "^8.5.6",
    "postcss-import": "^16.1.1",
    "prettier": "^3.7.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8"
  },
  "keywords": [
    "tailwindcss",
    "tailwind",
    "components",
    "component-library",
    "ui",
    "shadcn",
    "shadcn-ui",
    "design-system",
    "framework-agnostic",
    "accessible",
    "dark-mode",
    "css"
  ],
  "license": "MIT",
  "author": "Gufo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gufodotdev/starting-point-ui.git"
  },
  "homepage": "https://startingpointui.com",
  "bugs": {
    "url": "https://github.com/gufodotdev/starting-point-ui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
